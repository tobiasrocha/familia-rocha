rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Bloco base: nega tudo por padrão
    match /{document=**} {
      allow read, write: if false;
    }

    // Usuários autenticados podem ler e escrever nos dados da família
    match /financas/{doc} {
      allow read, write: if request.auth != null;
    }
    match /contas_bancarias/{doc} {
      allow read, write: if request.auth != null;
    }
    match /saldos_bancarios/{doc} {
      allow read, write: if request.auth != null;
    }
    match /cartoes/{doc} {
      allow read, write: if request.auth != null;
    }
    match /investimentos/{doc} {
      allow read, write: if request.auth != null;
    }
    match /tarefas/{doc} {
      allow read, write: if request.auth != null;
    }
    match /saude/{doc} {
      allow read, write: if request.auth != null;
    }
    match /estudos/{doc} {
      allow read, write: if request.auth != null;
    }
    match /disciplinas/{doc} {
      allow read, write: if request.auth != null;
    }
    match /patrimonio/{doc} {
      allow read, write: if request.auth != null;
    }
    match /viagens/{doc} {
      allow read, write: if request.auth != null;
    }
    match /viagens/{viagemId}/roteiros/{doc} {
      allow read, write: if request.auth != null;
    }
    match /viagens/{viagemId}/checklists/{doc} {
      allow read, write: if request.auth != null;
    }
    match /espiritual/{doc} {
      allow read, write: if request.auth != null;
    }
    match /perfis/{doc} {
      allow read, write: if request.auth != null;
    }
    match /emprestimos/{doc} {
      allow read, write: if request.auth != null;
    }
    match /salarios/{doc} {
      allow read, write: if request.auth != null;
    }
    match /carteira/{doc} {
      allow read, write: if request.auth != null;
    }

    // Coleção de usuários: somente superadmin pode ler/escrever
    match /usuarios/{doc} {
      allow read, write: if request.auth != null
        && request.auth.token.email == 'tobiasrocha@gmail.com';
    }
  }
}
